# ============================================================
# Fantacalcio Statistico — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase project URL and anon key (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — NEVER expose this in the browser.
# Only used in server-side code for privileged operations (seed, admin).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL (used for redirects in auth flows)
NEXT_PUBLIC_APP_URL=http://localhost:3000
