# ============================================================
# Fantacalcio Statistico — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase project URL and anon key (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — NEVER expose this in the browser.
# Only used in server-side code for privileged operations (seed, admin).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL (used for redirects in auth flows)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for the SportMonks cron endpoints
# (app/api/cron/sportmonks-*). Must match the value sent in the
# Authorization: Bearer header by the cron caller — set it both here
# (Vercel env vars) and in cron-job.org for each scheduled job.
# See docs/sportmonks-setup.md.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# SportMonks v3 Football API token. Server-only — NEVER expose to browser.
# Rotation plan:
#   ~2026-06-01  World Cup plan token (FantaMondiale goes live)
#   ~2026-08-01  Starter plan token   (Serie A 26/27 goes live)
# See docs/runbook-jun1-aug1.md for the full flip procedure.
SPORTMONKS_API_TOKEN=replace-on-jun-1-with-world-cup-plan-token
